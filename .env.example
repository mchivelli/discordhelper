###############################################
#          Discord Task Bot Configuration          #
###############################################

# Discord API Configuration
DISCORD_TOKEN=your_discord_token_here      # Required: Bot token from Discord Developer Portal
CLIENT_ID=your_bot_client_id_here          # Required: Application ID from Discord Developer Portal
GUILD_ID=your_development_server_id        # Optional: If set, commands will only register to this guild (faster updates for dev)

# OpenRouter AI Configuration
OPENROUTER_API_KEY=sk-or-xxxxxxxxxxxxxxxx  # Required: API key from OpenRouter
MODEL_NAME=gemini-2.0-flash-exp:free       # Required: AI model to use for task prerequisites and announcements
SUMMARIZATION_MODEL=anthropic/claude-3.5-haiku  # Optional: AI model to use for chat summarization
SUMMARY_CRON=0 8 * * *                    # Optional: Cron schedule for daily summaries (default: 8am daily)

# Ask Command Configuration
ASK_TOKEN_BUDGET=8000                    # Token budget for /ask (default: 8000)
ASK_MAX_RESPONSE_TOKENS=1000             # Max AI response tokens (default: 1000)
ASK_MODEL=anthropic/claude-3.5-haiku     # Model for /ask (defaults to SUMMARIZATION_MODEL)

# Preprocessing Configuration
PREPROCESSING_REMOVE_FORMATTING=true     # Remove Discord markdown
PREPROCESSING_REMOVE_CODE_BLOCKS=true    # Remove code blocks
PREPROCESSING_AGGRESSIVE_WHITESPACE=true # Condense whitespace

# ---- Anthropic SDK path (strictly opt-in) ----
# To use the Anthropic SDK directly, set BOTH the key and at least one CLAUDE_*_MODEL var.
# Without an explicit model, the bot falls through to OpenRouter (which can also serve Anthropic via slugs).
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxx  # Optional: Anthropic API key for Claude SDK
CLAUDE_FAST_MODEL=                         # Optional: e.g. claude-haiku-4-5 — required to enable Anthropic SDK for fast calls
CLAUDE_SMART_MODEL=                        # Optional: e.g. claude-sonnet-4-5 — required to enable Anthropic SDK for smart calls

# ---- OpenRouter fast/smart tiering (works for any provider) ----
# When Anthropic SDK is off, these control which model is used per call tier.
LLM_FAST_MODEL=anthropic/claude-haiku-4-5  # Optional: cheap model for /sentiment, /tldr, mod-AI, summaries
LLM_SMART_MODEL=anthropic/claude-sonnet-4-5  # Optional: smarter model for /ask, /insights, /analyse

# Embedding Configuration (for semantic search)
EMBEDDING_MODEL=openai/text-embedding-3-small  # Optional: Embedding model for semantic search

# Persistence Settings
DB_PATH=./data/bot.db                      # Optional: Path to SQLite database file (default: ./data/bot.db)

# ---- Sync Configuration ----
# REQUIRED for semantic search features (/ask, /search, /tldr). Comma-separated channel IDs.
# If empty, the daily sync cron is a no-op (safety guard against unbounded API spend).
SYNC_CHANNEL_IDS=                          # REQUIRED: e.g. 123456789012345678,234567890123456789
SYNC_BACKFILL_DAYS=14                      # Optional: Number of days to backfill on first sync (default: 14)
SYNC_CRON=0 3 * * *                        # Optional: Cron schedule for daily sync (default: 3am daily)

# Daily Summary Configuration
DAILY_SUMMARY_CHANNEL_ID=                  # Optional: Channel ID to post daily summaries to
DAILY_SUMMARY_SOURCE_CHANNELS=             # Optional: Comma-separated channel IDs to include when generating daily summaries (also filters which channels' messages are stored)

# ---- Moderation / AI auto-detection ----
MOD_REPORT_CHANNEL_ID=                     # Optional: Channel ID to post moderation reports to
MOD_SENSITIVITY=0.5                        # Optional: Sensitivity threshold for toxicity flagging (0-1, default: 0.5)
MOD_MIN_LENGTH=20                          # Optional: Skip mod-AI on messages shorter than N chars (default: 20)
MOD_CHANNEL_IDS=                           # Optional: Comma-separated channels to run toxicity detection on (empty = all readable channels)
QUESTION_CHANNEL_IDS=                      # Optional: Comma-separated channels to run question detection on (empty = all readable channels)
ENABLE_TOXICITY_DETECTION=true             # Optional: Master switch for toxicity detection (default: true). Set 'false' to disable everywhere.
ENABLE_QUESTION_DETECTION=true             # Optional: Master switch for question detection (default: true). Set 'false' to disable everywhere.

# Reminder Configuration
REMINDER_CRON=0 9 * * *                    # Optional: Cron schedule for daily reminders (default: 9am daily)
REMINDER_CHANNEL_ID=                       # Optional: Channel ID to post daily reminders to (falls back to system/first text channel)

# Message Retention & Cleanup
MESSAGE_RETENTION_DAYS=30                  # Optional: Number of days to keep chat messages before auto-deletion (default: 30, set to 0 to disable cleanup)
MESSAGE_CLEANUP_CRON=0 3 * * *            # Optional: Cron schedule for message cleanup (default: 3am daily)

# Logging Configuration
LOG_LEVEL=info                             # Optional: Logging level (error, warn, info, debug) - default: info

# Changelog and Patch Configuration
CHANGELOG_CHANNEL_ID=                      # Optional: Default channel ID for posting changelog entries

# Environment
NODE_ENV=development                       # Optional: Environment (development, production) - default: development
